OPENAI_API_KEY=sk-your-openai-api-key
STT_PROVIDER=openai
STT_MODEL=gpt-4o-mini-transcribe
STT_MODE=realtime # or batch
STT_LANGUAGE= # optional; set ru/en or leave empty for OpenAI auto-detect
STT_PROMPT=
HOTKEY_MODE=hold # hold or toggle
HOTKEY_START=ctrl+space
HOTKEY_STOP=ctrl+shift+space # used in toggle mode
DISABLE_LLM=false
PROMPT="Transcribe clearly with correct punctuation, capitalization, and paragraphing. Preserve technical terms."
DEEPGRAM=
COST_STT_AUDIO_INPUT_USD_PER_1M=3.00
COST_STT_AUDIO_USD_PER_MINUTE=0.003
COST_STT_TEXT_INPUT_USD_PER_1M=0
COST_STT_OUTPUT_USD_PER_1M=0
COST_LLM_INPUT_USD_PER_1M=0.15
COST_LLM_OUTPUT_USD_PER_1M=0.60
